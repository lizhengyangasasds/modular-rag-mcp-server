# Modular RAG MCP Server - Environment Variables
# Copy this file to .env and fill in your actual keys.
# IMPORTANT: .env is in .gitignore — do NOT commit actual keys.

# DeepSeek API key (required for LLM)
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Vision LLM API key (optional — for image captioning in PDFs)
# Supported providers: OpenAI (gpt-4o), Azure OpenAI
VISION_LLM_API_KEY=sk-your-vision-api-key-here

# Optional: Override default collection name (default: knowledge_hub)
# COLLECTION_NAME=knowledge_hub
